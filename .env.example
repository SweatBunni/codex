# CodexMC v2 — Environment Config
# Copy to .env.local and fill in values

# OpenRouter API Key (FREE) — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use (deepseek/deepseek-r1:free is free and great!)
OPENROUTER_MODEL=deepseek/deepseek-r1:free

# Your site URL — shown to OpenRouter as referrer (optional)
NEXT_PUBLIC_SITE_URL=http://your-server-ip-or-domain

# Port for the standalone server
PORT=3000
