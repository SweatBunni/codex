# CodexMC v3 - Environment Configuration
# Copy this to .env and fill in your values

# AI Configuration
# OpenRouter API Key - get one free at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Primary free model for architecture + generation
OPENROUTER_MODEL=qwen/qwen3.6-plus-preview:free

# Free coding-focused fallback used if the primary model fails or needs repair
OPENROUTER_FALLBACK_MODEL=qwen/qwen3-coder:free

# low | medium | high
OPENROUTER_REASONING_EFFORT=medium

# Server
PORT=3000
NODE_ENV=production
SITE_URL=https://your-domain.com

# Workspace
WORKSPACE_DIR=./data/workspaces
MAX_CONCURRENT_BUILDS=3
BUILD_TIMEOUT_MS=300000

# Java Paths (auto-detected if not set)
# JAVA_8_HOME=/usr/lib/jvm/java-8-openjdk-amd64
# JAVA_17_HOME=/usr/lib/jvm/java-17-openjdk-amd64
# JAVA_21_HOME=/usr/lib/jvm/java-21-openjdk-amd64

# Rate Limiting
MAX_REQUESTS_PER_HOUR=20
