# CodexMC — Environment Config
# Copy to .env and fill in values

# ─── LM Studio ───────────────────────────────────────────────────────────────
# LM Studio runs a local OpenAI-compatible server. Start it with:
#   lms server start
# Docs: https://lmstudio.ai/docs/api

# URL of your LM Studio server (default: http://localhost:1234)
LM_STUDIO_URL=http://localhost:1234

# Model to use — must match a model you have loaded in LM Studio.
# Run `lms get <model>` to download, or pick one in the LM Studio UI.
# Examples:
#   openai/gpt-oss-20b
#   lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF
# Leave as "local-model" to use whatever is currently loaded.
LM_STUDIO_MODEL=local-model

# Optional: a separate (usually smaller/faster) model for repair passes.
# Defaults to LM_STUDIO_MODEL if not set.
# LM_STUDIO_FAST_MODEL=local-model

# Optional: bearer token — only needed if you enabled auth in LM Studio.
# LM_API_TOKEN=your_token_here

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
SITE_URL=https://your-domain.com

# ─── Workspace ───────────────────────────────────────────────────────────────
WORKSPACE_DIR=/tmp/codexmc-workspaces

# ─── JDK Paths ───────────────────────────────────────────────────────────────
JDK_8_PATH=/opt/jdk/8
JDK_17_PATH=/opt/jdk/17
JDK_21_PATH=/opt/jdk/21
JDK_25_PATH=/opt/jdk/25

# ─── Limits ──────────────────────────────────────────────────────────────────
MAX_REQUESTS_PER_HOUR=20
MAX_CONCURRENT_BUILDS=3
BUILD_TIMEOUT_MS=300000
