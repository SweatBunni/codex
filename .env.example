# CodexMC — Environment Config (puter.js edition)
# Copy to .env and fill in values

# ─── Puter.js AI ─────────────────────────────────────────────────
# Optional: set your Puter API token for server-side auth.
# If left blank, the server will attempt anonymous/user-authenticated access.
# Get a token at: https://puter.com → Settings → API Tokens
PUTER_API_TOKEN=your_puter_api_token_here

# AI model to use for code generation (puter.js model ID)
# Options: claude-sonnet-4-5, gpt-4o, gemini-2.5-flash, etc.
# Full list: https://docs.puter.com/AI/chat/
PUTER_MODEL=claude-sonnet-4-5

# Faster/cheaper model used for repair passes
PUTER_FAST_MODEL=claude-sonnet-4-5

# ─── Server ──────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
SITE_URL=https://your-domain.com

# ─── Workspace (temp storage for builds) ─────────────────────────
WORKSPACE_DIR=/tmp/codexmc-workspaces

# ─── JDK Paths ───────────────────────────────────────────────────
JDK_8_PATH=/opt/jdk/8
JDK_17_PATH=/opt/jdk/17
JDK_21_PATH=/opt/jdk/21

# ─── Limits ──────────────────────────────────────────────────────
MAX_REQUESTS_PER_HOUR=20
MAX_CONCURRENT_BUILDS=3
BUILD_TIMEOUT_MS=300000
