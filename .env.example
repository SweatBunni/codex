# CodexMC v2.0 - Environment Configuration
# Copy to .env and fill in values

# AI Configuration
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_MODEL=mistralai/mistral-7b-instruct
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7

# Alternative AI Providers (optional)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
SITE_URL=https://your-domain.com
CORS_ORIGIN=*

# Database Configuration
DB_TYPE=sqlite
DATABASE_URL=./data/codexmc.db
# REDIS_URL=redis://localhost:6379  # For production with Redis

# Workspace Configuration
WORKSPACE_DIR=./data/workspaces
TEMPLATE_GRADLE_DIR=./templates
MAX_CONCURRENT_BUILDS=3
BUILD_TIMEOUT_MS=300000

# Java Configuration
JDK_8_PATH=/opt/jdk/8
JDK_17_PATH=/opt/jdk/17
JDK_21_PATH=/opt/jdk/21
JDK_25_PATH=/opt/jdk/25

# Rate Limiting
MAX_REQUESTS_PER_HOUR=20
MAX_SESSION_LENGTH=100
MAX_PROMPT_LENGTH=5000

# Security
SESSION_SECRET=your-session-secret-here
JWT_SECRET=your-jwt-secret-here
BCRYPT_ROUNDS=12

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
