# CodexMC — Environment Config
# Copy to .env and fill in values

# OpenRouter API Key (FREE) — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model: deepseek/deepseek-r1:free — Best free reasoning model (no cost!)
# No ChatGPT/Anthropic key needed

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
SITE_URL=https://your-domain.com

# Workspace (temp storage for builds)
WORKSPACE_DIR=/tmp/codexmc-workspaces

# JDK Paths
JDK_8_PATH=/opt/jdk/8
JDK_17_PATH=/opt/jdk/17
JDK_21_PATH=/opt/jdk/21
JDK_25_PATH=/opt/jdk/25

# Limits
MAX_REQUESTS_PER_HOUR=20
MAX_CONCURRENT_BUILDS=3
BUILD_TIMEOUT_MS=300000
